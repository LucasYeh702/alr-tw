# ALR-TW v0.6.0 public preview. Never commit real credentials.

# Default: synthetic (offline, no external requests).
# Live choices: official_only | hybrid_verified
ALR_TW_DATA_MODE=synthetic

# Managed SQLite state. Default: ~/.cache/alr-tw
# ALR_TW_STORAGE_PATH=~/.cache/alr-tw

# 1s..7d; default 24h. Per-run MCP constraints may use "ephemeral".
ALR_TW_RETENTION=24h

# TLR is contacted only in hybrid_verified mode after the privacy gate.
ALR_TW_TLR_BASE_URL=https://tlr.dr-lawbot.com
# ALR_TW_TLR_API_KEY=

# Legacy opt-in demo path for a resolver-backed judgment cache.
# ALR_TW_IDENTIFIER_BACKED_VERIFIED_CACHE=0
